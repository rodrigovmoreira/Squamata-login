{
  "name": "squamata-login-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @squamata-login/frontend\" \"npm run dev -w @squamata-login/backend\"",
    "install:all": "npm install",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "next-themes": "^0.4.6",
    "react-icons": "^5.6.0"
  }
}
